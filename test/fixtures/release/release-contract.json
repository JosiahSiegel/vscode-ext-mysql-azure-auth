    "view:mysqlAzureAuth.welcomeAction": { "kind": "view", "id": "mysqlAzureAuth.welcomeAction", "disposition": "INTERNAL", "reason": "internal programmatic" },
    "setting:mysqlAzureAuth.servers": { "kind": "setting", "id": "mysqlAzureAuth.servers", "disposition": "REMOVE", "reason": "unused / unread" },
    "setting:mysqlAzureAuth.connectionColors": { "kind": "setting", "id": "mysqlAzureAuth.connectionColors", "disposition": "REMOVE", "reason": "unused / unread" },
    "setting:mysqlAzureAuth.historyLimit": { "kind": "setting", "id": "mysqlAzureAuth.historyLimit", "disposition": "KEEP" },
    "setting:mysqlAzureAuth.showRowCounts": { "kind": "setting", "id": "mysqlAzureAuth.showRowCounts", "disposition": "KEEP" },
    "setting:mysqlAzureAuth.enableStatusBar": { "kind": "setting", "id": "mysqlAzureAuth.enableStatusBar", "disposition": "KEEP" }
