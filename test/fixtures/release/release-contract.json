    "command:mysqlAzureAuth.disconnectServer": { "kind": "command", "id": "mysqlAzureAuth.disconnectServer", "disposition": "KEEP", "title": "Close Session" },
    "command:mysqlAzureAuth.openWorkbench": { "kind": "command", "id": "mysqlAzureAuth.openWorkbench", "disposition": "KEEP", "title": "Open Workbench" },
    "command:mysqlAzureAuth.refreshAll": { "kind": "command", "id": "mysqlAzureAuth.refreshAll", "disposition": "KEEP", "title": "Refresh All" },
