{
  "schemaVersion": 1,
  "case": "editRows-revived",
  "description": "Regression fixture: the editRows command has crept back into contributes.commands alongside its successor viewMoreRows. Validator must emit EDIT_ROWS_REVIVED and exit 1 before any later check.",
  "manifest": {
    "name": "mysql-azure-auth",
    "displayName": "MySQL Azure Auth",
    "description": "A community-maintained VS Code preview for browsing and querying Azure Database for MySQL Flexible Server with Microsoft Entra authentication.",
    "version": "0.1.0",
    "activationEvents": [
      "onView:mysqlAzureAuth.serversView",
      "onCommand:mysqlAzureAuth.registerServer",
      "onCommand:mysqlAzureAuth.connectServer",
      "onCommand:mysqlAzureAuth.disconnectServer",
      "onCommand:mysqlAzureAuth.openWorkbench",
      "onCommand:mysqlAzureAuth.previewRows",
      "onCommand:mysqlAzureAuth.viewMoreRows",
      "onCommand:mysqlAzureAuth.forgetServer",
      "onCommand:mysqlAzureAuth.editServer",
      "onCommand:mysqlAzureAuth.refreshAll",
      "onView:mysqlAzureAuth.welcomeView"
    ],
    "contributes": {
      "commands": [
        { "command": "mysqlAzureAuth.registerServer", "title": "Register Server" },
        { "command": "mysqlAzureAuth.forgetServer", "title": "Forget Server" },
        { "command": "mysqlAzureAuth.editServer", "title": "Edit Server" },
        { "command": "mysqlAzureAuth.connectServer", "title": "Open Session" },
        { "command": "mysqlAzureAuth.disconnectServer", "title": "Close Session" },
        { "command": "mysqlAzureAuth.openWorkbench", "title": "Open Workbench" },
        { "command": "mysqlAzureAuth.refreshAll", "title": "Refresh All" },
        { "command": "mysqlAzureAuth.previewRows", "title": "Preview Rows" },
        { "command": "mysqlAzureAuth.viewMoreRows", "title": "View More Rows" },
        { "command": "mysqlAzureAuth.editRows", "title": "Edit Rows" }
      ],
      "configuration": {
        "title": "MySQL Azure Auth",
        "properties": {
          "mysqlAzureAuth.historyLimit": { "type": "number", "default": 100 },
          "mysqlAzureAuth.showRowCounts": { "type": "boolean", "default": true },
          "mysqlAzureAuth.enableStatusBar": { "type": "boolean", "default": true }
        }
      }
    }
  }
}
