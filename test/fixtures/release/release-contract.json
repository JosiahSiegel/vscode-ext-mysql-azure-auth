{
  "schemaVersion": 1,
  "productSentence": "A community-maintained VS Code preview for browsing and querying Azure Database for MySQL Flexible Server with Microsoft Entra authentication.",
  "items": {
    "command:mysqlAzureAuth.registerServer": { "kind": "command", "id": "mysqlAzureAuth.registerServer", "disposition": "KEEP", "title": "Register Server…" },
    "command:mysqlAzureAuth.forgetServer": { "kind": "command", "id": "mysqlAzureAuth.forgetServer", "disposition": "KEEP", "title": "Forget Server" },
